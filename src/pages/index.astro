<style>
/* Mobile Menu Slide-Out */
.sm-mobile-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 99998;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}
.sm-mobile-overlay.active {
  opacity: 1;
  visibility: visible;
}
.sm-mobile-panel {
  position: fixed;
  top: 0;
  right: -300px;
  width: 280px;
  height: 100%;
  background: #fff;
  z-index: 99999;
  transition: right 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: -4px 0 20px rgba(0,0,0,0.15);
  display: flex;
  flex-direction: column;
}
.sm-mobile-panel.active {
  right: 0;
}
.sm-mobile-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 20px;
  border-bottom: 1px solid #eee;
}
.sm-mobile-panel-header span {
  font-family: 'Jost', sans-serif;
  font-weight: 600;
  font-size: 18px;
  color: #222;
}
.sm-mobile-close {
  width: 32px;
  height: 32px;
  border: none;
  background: #8B0000;
  color: #fff;
  border-radius: 50%;
  font-size: 18px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}
.sm-mobile-close:hover {
  background: #a00;
}
.sm-mobile-nav {
  list-style: none;
  margin: 0;
  padding: 20px 0;
}
.sm-mobile-nav li {
  border-bottom: 1px solid #f0f0f0;
}
.sm-mobile-nav a {
  display: block;
  padding: 14px 24px;
  font-family: 'Jost', sans-serif;
  font-size: 16px;
  font-weight: 500;
  color: #222;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}
.sm-mobile-nav a:hover {
  background: #f8f0f0;
  color: #8B0000;
}
</style>

<!-- Mobile Menu Panel -->
<div class="sm-mobile-overlay" id="smMobileOverlay"></div>
<div class="sm-mobile-panel" id="smMobilePanel">
  <div class="sm-mobile-panel-header">
    <span>Menu</span>
    <button class="sm-mobile-close" id="smMobileClose" aria-label="Close menu">&times;</button>
  </div>
  <ul class="sm-mobile-nav">
    <li><a href="/">Home</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/our-course">Our Course</a></li>
    <li><a href="/contact">Contact</a></li>
  </ul>
</div>

<script is:inline>
(function() {
  var toggleBtns = document.querySelectorAll('.jet-mobile-menu__toggle');
  var overlay = document.getElementById('smMobileOverlay');
  var panel = document.getElementById('smMobilePanel');
  var closeBtn = document.getElementById('smMobileClose');

  function openMenu() {
    overlay.classList.add('active');
    panel.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    overlay.classList.remove('active');
    panel.classList.remove('active');
    document.body.style.overflow = '';
  }

  toggleBtns.forEach(function(btn) {
    btn.addEventListener('click', openMenu);
  });
  if (closeBtn) closeBtn.addEventListener('click', closeMenu);
  if (overlay) overlay.addEventListener('click', closeMenu);

  // Close on Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeMenu();
  });
})();

// Custom Hero Slider Auto-loop & Navigation
document.addEventListener('DOMContentLoaded', () => {
  const slides = document.querySelectorAll('.sm-hero-slide');
  const dots = document.querySelectorAll('.sm-hero-dot');
  
  if (slides.length > 0) {
    let current = 0;
    let slideInterval;

    const goToSlide = (index) => {
      slides[current].classList.remove('active');
      if(dots.length > 0) dots[current].classList.remove('active');
      
      current = index;
      
      slides[current].classList.add('active');
      if(dots.length > 0) dots[current].classList.add('active');
    };

    const nextSlide = () => {
      goToSlide((current + 1) % slides.length);
    };

    const startSlideShow = () => {
      slideInterval = setInterval(nextSlide, 4000); // Change slide every 4 seconds
    };

    // Initialize first slide and dot
    slides[current].classList.add('active');
    if(dots.length > 0) dots[current].classList.add('active');

    // Add click events to dots
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        clearInterval(slideInterval);
        goToSlide(index);
        startSlideShow();
      });
    });

    // Start auto-slide
    startSlideShow();
  }
});

// ═══════════════════════════════════════════════════════
//  EBOOK POPUP LOGIC
//  No cooldown — popup shows on EVERY page load/refresh.
//  The fired flag is in-memory only, so it resets each visit.
// ═══════════════════════════════════════════════════════
(function () {
  const overlay  = document.getElementById('sm-ebook-overlay');
  const closeBtn = document.getElementById('sm-popup-close-btn');
  const form     = document.getElementById('sm-ebook-form');

  if (!overlay) return;

  // ── Open / Close ─────────────────────────────────────
  function openPopup() {
    overlay.classList.add('sm-popup-open');
    document.body.style.overflow = 'hidden';
  }

  function closePopup() {
    overlay.classList.remove('sm-popup-open');
    document.body.style.overflow = '';
    window.removeEventListener('scroll', onScroll);
  }

  // ── Scroll trigger ───────────────────────────────────
  // Fire as soon as the user scrolls more than 80% of the
  // viewport height — i.e. they have scrolled past the hero.
  let fired = false;
  const THRESHOLD = window.innerHeight * 0.8;

  function onScroll() {
    if (fired) return;
    if (window.scrollY > THRESHOLD) {
      fired = true;
      window.removeEventListener('scroll', onScroll);
      openPopup();
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });

  // ── Close handlers ────────────────────────────────────
  closeBtn && closeBtn.addEventListener('click', closePopup);

  overlay.addEventListener('click', function (e) {
    if (e.target === overlay) closePopup();
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && overlay.classList.contains('sm-popup-open')) closePopup();
  });

  // ── Footer "Download Free Career Guide" button ────────
  var footerBtn = document.getElementById('sm-footer-ebook-btn');
  footerBtn && footerBtn.addEventListener('click', function () {
    // Reset the fired flag so popup can reopen from footer button even if already triggered
    fired = false;
    openPopup();
  });


  // ── Form submit → /thank-you ─────────────────────────
  form && form.addEventListener('submit', function (e) {
    e.preventDefault();
    const name  = form.querySelector('#sp-name').value.trim();
    const phone = form.querySelector('#sp-phone').value.trim();
    const email = form.querySelector('#sp-email').value.trim();

    // Inline validation — highlight empty fields in red
    let valid = true;
    [['#sp-name', name], ['#sp-phone', phone], ['#sp-email', email]].forEach(([sel, val]) => {
      const el = form.querySelector(sel);
      if (!val) { el.style.borderColor = '#B01615'; if (valid) { el.focus(); valid = false; } }
      else       { el.style.borderColor = ''; }
    });
    if (!valid) return;
    window.location.href = '/thank-you';
  });

  // Clear red borders on input
  form && form.querySelectorAll('.sm-popup-field').forEach(function (el) {
    el.addEventListener('input', function () { el.style.borderColor = ''; });
  });
})();
</script>
</body>
</html>
