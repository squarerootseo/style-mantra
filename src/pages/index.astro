    .elementor-element-7696bc1 { background-image: url('/images/career-9.jpeg') !important; }
    .elementor-element-021ab40 { background-image: url('/images/career-10.jpeg') !important; }

    @keyframes smMarqueeScroll {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-50%);
