    /* Careers Marquee Styles */
    .sm-careers-marquee {
      width: 100%;
      overflow: hidden;
      position: relative;
      padding: 20px 0;
    }

    .sm-careers-track {
      display: flex;
      width: max-content;
      animation: smMarqueeScroll 25s linear infinite;
    }

    .sm-careers-marquee:hover .sm-careers-track {
      animation-play-state: paused;
    }

    .sm-careers-track .elementor-column {
      width: 305px !important;
      min-width: 305px !important;
      margin-right: 20px;
      flex-shrink: 0;
      
      /* Image layout */
      position: relative !important;
      overflow: hidden !important;
      border-radius: 8px !important;
      min-height: 420px !important;
      padding: 168px 0 0 0 !important; /* Top 40% red box, 0 sides to align */
      background-origin: content-box !important;
      background-clip: border-box !important;
      background-size: cover !important;
      background-position: top center !important;
      background-color: transparent !important;
      /* Fix Safari border-radius clipping */
      -webkit-mask-image: -webkit-radial-gradient(white, black) !important;
      isolation: isolate !important;
    }

    /* Assign the 10 career images */
    .elementor-element-5504cd1 { background-image: url('/images/career-1.png') !important; }
    .elementor-element-0811d89 { background-image: url('/images/career-2.png') !important; }
